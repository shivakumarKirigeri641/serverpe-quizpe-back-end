{
  "version": "7.0",
  "screens": [
    {
      "id": "SIGNUP",
      "title": "Start Free Trial",
      "terminal": true,
      "success": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "signup_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Set up your free trial"
              },
              {
                "type": "TextBody",
                "text": "Just a few details and your child's daily quiz starts tonight at 8 PM."
              },
              {
                "type": "TextInput",
                "name": "student_name",
                "label": "Child's name",
                "input-type": "text",
                "required": true,
                "helper-text": "As it should appear on the report card"
              },
              {
                "type": "Dropdown",
                "name": "board",
                "label": "Board",
                "required": true,
                "data-source": [
                  {
                    "id": "CBSE",
                    "title": "CBSE"
                  },
                  {
                    "id": "ICSE",
                    "title": "ICSE"
                  },
                  {
                    "id": "KSEAB",
                    "title": "KSEAB"
                  }
                ]
              },
              {
                "type": "Dropdown",
                "name": "medium",
                "label": "Medium of instruction",
                "required": true,
                "data-source": [
                  {
                    "id": "ENGLISH",
                    "title": "English"
                  }
                ]
              },
              {
                "type": "Dropdown",
                "name": "grade",
                "label": "Grade",
                "required": true,
                "data-source": [
                  {
                    "id": "G1",
                    "title": "Grade 1"
                  },
                  {
                    "id": "G2",

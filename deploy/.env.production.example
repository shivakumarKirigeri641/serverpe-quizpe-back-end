# ---------------------------------------------------------------------------
# QuizPe production environment — copy to .env on the server and fill in.
# Never commit the filled-in version: it holds live payment and WhatsApp keys.
# ---------------------------------------------------------------------------

NODE_ENV=production
PORT=5008

# Nginx terminates TLS and proxies to this process. BEHIND_TLS turns on HSTS,
# upgrade-insecure-requests and trust-proxy (so rate limits see the real client
# IP rather than 127.0.0.1 — without it, one visitor's limit applies to all).
BEHIND_TLS=1

# --- domains ---------------------------------------------------------------
# Links sent to parents on WhatsApp (quiz, report, support, feedback, payment).
# These pages are served by this process, so they live on the API host.
PUBLIC_BASE_URL=https://api.quizpe.in
# The marketing site, used in SEO tags, invoices and policy documents.
SITE_URL=https://quizpe.in

# Browsers allowed to call this API. Exact scheme + host, comma-separated.
ADMIN_ORIGINS=https://admin.quizpe.in
SITE_ORIGINS=https://quizpe.in,https://www.quizpe.in

# Nginx serves the built front-ends, so this process should not.
SERVE_FRONTENDS=0

# --- database --------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=serverpe_quizpe
DB_USER=quizpe
DB_PASSWORD=CHANGE_ME

# --- admin panel -----------------------------------------------------------
# MUST be a long random string in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=CHANGE_ME
ADMIN_TOKEN_HOURS=2
# TODO before go-live: replace the PIN with SMS/OTP.
ADMIN_PIN=CHANGE_ME

# --- WhatsApp Cloud API ----------------------------------------------------
WHATSAPP_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_VERIFY_TOKEN=CHANGE_ME

# --- Razorpay (LIVE keys, not test) ----------------------------------------
RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

# --- quiz window -----------------------------------------------------------
QUIZ_WINDOW_OPEN=19:00
QUIZ_WINDOW_CLOSE=23:45
REMINDER_LEAD_MIN=30
CUTOFF_HHMM=23:50
TZ=Asia/Kolkata
